generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  role         String // admin, warehouse_staff, billing_staff, project_manager
  phone        String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLogin    DateTime? @map("last_login")

  // Relations
  managedProjects       Project[]        @relation("ProjectManager")
  createdPurchaseOrders PurchaseOrder[]  @relation("POCreator")
  createdGatePasses     GatePass[]       @relation("GatePassCreator")
  stockMovements        StockMovement[]  @relation("MovementPerformer")
  auditLogs             AuditLog[]
  permissions           UserPermission[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model UserPermission {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  resource  String // inventory, projects, gatepass, purchase_orders, suppliers, users, analytics, settings
  canView   Boolean  @default(false) @map("can_view")
  canCreate Boolean  @default(false) @map("can_create")
  canEdit   Boolean  @default(false) @map("can_edit")
  canDelete Boolean  @default(false) @map("can_delete")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resource])
  @@index([userId])
  @@map("user_permissions")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  parent     Category?   @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children   Category[]  @relation("CategoryHierarchy")
  items      Item[]
  attributes Attribute[]

  @@index([parentId])
  @@map("categories")
}

// EAV Model: Attributes define dynamic fields per category
model Attribute {
  id                   String   @id @default(uuid())
  categoryId           String   @map("category_id")
  name                 String
  label                String
  inputType            String   @map("input_type") // text, number, dropdown, checkbox, file, date, email, url, textarea
  required             Boolean  @default(false)
  options              String? // JSON array for dropdown/checkbox: ["Option1","Option2"]
  validationRules      String?  @map("validation_rules") // JSON object: {"min":0,"max":100}
  helpText             String?  @map("help_text")
  displayOrder         Int      @default(0) @map("display_order")
  conditionalAppearance String? @map("conditional_appearance") // JSON: {"dependsOn":"material_type","showForValues":["MS","SS"]}
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  category Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  values   ItemAttributeValue[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("attributes")
}

// EAV Model: Stores actual attribute values for items
model ItemAttributeValue {
  id          String   @id @default(uuid())
  itemId      String   @map("item_id")
  attributeId String   @map("attribute_id")
  value       String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  attribute Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([itemId, attributeId])
  @@index([itemId])
  @@index([attributeId])
  @@map("item_attribute_values")
}

model Item {
  id                String   @id @default(uuid())
  barcode           String   @unique
  name              String
  description       String?
  categoryId        String?  @map("category_id")
  brand             String?
  unitOfMeasurement String   @map("unit_of_measurement")
  currentQuantity   Decimal  @default(0) @map("current_quantity")
  minStockLevel     Decimal  @default(0) @map("min_stock_level")
  maxStockLevel     Decimal? @map("max_stock_level")
  reorderLevel      Decimal  @default(0) @map("reorder_level")
  reorderQuantity   Decimal  @default(0) @map("reorder_quantity")
  unitCost          Decimal? @map("unit_cost")
  sellingPrice      Decimal? @map("selling_price")
  location          String?
  imageUrl          String?  @map("image_url")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  category           Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  attributeValues    ItemAttributeValue[]
  stockMovements     StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  gatePassItems      GatePassItem[]

  @@index([barcode])
  @@index([categoryId])
  @@index([name])
  @@map("items")
}

model Project {
  id               String    @id @default(uuid())
  projectCode      String    @unique @map("project_code")
  name             String
  description      String?
  siteAddress      String    @map("site_address")
  projectManagerId String?   @map("project_manager_id")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  budget           Decimal?
  status           String    @default("active") // active, completed, on_hold, cancelled
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  projectManager User?           @relation("ProjectManager", fields: [projectManagerId], references: [id])
  stockMovements StockMovement[]
  gatePasses     GatePass[]
  purchaseOrders PurchaseOrder[]

  @@index([projectCode])
  @@index([projectManagerId])
  @@map("projects")
}

